{
  "name": "@zumer/snapeye",
  "version": "0.1.0",
  "description": "A tiny bridge that lets a coding agent see your running web app. snapDOM client + a two-endpoint HTTP handler — that's it.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".":         "./src/index.js",
    "./client":  "./src/client.js",
    "./server":  "./src/server.js"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "snapdom",
    "agent",
    "ai",
    "visual",
    "screenshot",
    "claude",
    "cursor",
    "aider",
    "bridge",
    "zumerlab"
  ],
  "author": "Juan Martin Muda - Zumerlab",
  "license": "MIT",
  "scripts": {
    "bump:dry": "npx @zumerbox/bump -d",
    "bump":     "npx @zumerbox/bump && npx @zumerbox/changelog",
    "prebuild": "git add CHANGELOG.md && git commit -m \"Bumped version\" && git push --follow-tags",
    "build":    "npm pack"
  },
  "homepage": "https://github.com/zumerlab/snapeye#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zumerlab/snapeye.git"
  },
  "bugs": {
    "url": "https://github.com/zumerlab/snapeye/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@zumer/snapdom": "^2.12.0"
  },
  "peerDependenciesMeta": {
    "@zumer/snapdom": { "optional": false }
  },
  "publishConfig": {
    "access": "public"
  }
}
